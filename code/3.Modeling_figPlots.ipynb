    "\n",
    "\n",
    "def plot_roc_curves(all_fpr, all_tpr, all_y_true, all_y_proba, mice_sorted,\n",
    "                   save_path_individual, save_path_overall,optimal_cutoff=0.5):\n",
    "    \"\"\"绘制每个fold的ROC曲线和总体ROC曲线（包括95%CI）\"\"\"\n",
    "    # 个体ROC曲线\n",
    "    fig, ax = plt.subplots(figsize=(10, 8))\n",
    "    \n",
    "    for i, (fpr, tpr, mouse) in enumerate(zip(all_fpr, all_tpr, mice_sorted)):\n",
    "        auc_val = auc(fpr, tpr)\n",
    "        ax.plot(fpr, tpr, linewidth=2, label=f'{mouse} (AUC={auc_val:.3f})')\n",
    "    \n",
    "    ax.plot([0, 1], [0, 1], 'k--', linewidth=2, label='随机分类器')\n",
    "    ax.set_xlabel('假阳性率 (FPR)', fontsize=12, fontweight='bold')\n",
    "    ax.set_ylabel('真阳性率 (TPR)', fontsize=12, fontweight='bold')\n",
    "    ax.set_title('ROC曲线 - 各Fold', fontsize=14, fontweight='bold')\n",
    "    ax.legend(loc='lower right', fontsize=10)\n",
    "    ax.grid(alpha=0.3)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.savefig(save_path_individual, format='pdf', bbox_inches='tight')\n",
    "    plt.close()\n",
    "    print(f\"个体ROC曲线已保存: {save_path_individual}\")\n",
    "    \n",
    "    # 总体ROC曲线（Micro-average + Bootstrap 95%CI）\n",
    "    fig, ax = plt.subplots(figsize=(10, 8))\n",
    "    \n",
    "    # 计算总体AUC\n",
    "    overall_auc = roc_auc_score(all_y_true, all_y_proba)\n",
    "    fpr_overall, tpr_overall, _ = roc_curve(all_y_true, all_y_proba)\n",
    "    \n",
    "    # Bootstrap计算95%置信区间\n",
    "    n_bootstraps = 1000\n",
    "    rng = np.random.RandomState(42)\n",
    "    bootstrapped_aucs = []\n",
    "    \n",
    "    # 用于插值的通用FPR\n",
    "    mean_fpr = np.linspace(0, 1, 100)\n",
    "    tprs = []\n",
    "    \n",
    "    for i in range(n_bootstraps):\n",
    "        indices = rng.randint(0, len(all_y_true), len(all_y_true))\n",
    "        if len(np.unique(all_y_true[indices])) < 2:\n",
    "            continue\n",
    "        \n",
    "        fpr, tpr, _ = roc_curve(all_y_true[indices], all_y_proba[indices])\n",
    "        bootstrapped_aucs.append(auc(fpr, tpr))\n",
    "        \n",
    "        # 插值到统一的FPR\n",
    "        interp_tpr = np.interp(mean_fpr, fpr, tpr)\n",
    "        interp_tpr[0] = 0.0\n",
    "        tprs.append(interp_tpr)\n",
    "    \n",
    "    # 计算置信区间\n",
    "    auc_lower = np.percentile(bootstrapped_aucs, 2.5)\n",
    "    auc_upper = np.percentile(bootstrapped_aucs, 97.5)\n",
    "    \n",
    "    mean_tpr = np.mean(tprs, axis=0)\n",
    "    mean_tpr[-1] = 1.0\n",
    "    std_tpr = np.std(tprs, axis=0)\n",
    "    tpr_upper = np.minimum(mean_tpr + 1.96*std_tpr, 1)\n",
    "    tpr_lower = np.maximum(mean_tpr - 1.96*std_tpr, 0)\n",
    "    \n",
    "    # 绘制ROC曲线\n",
    "    ax.plot(fpr_overall, tpr_overall, color='blue', linewidth=3,\n",
    "           label=f'总体 ROC (AUC={overall_auc:.3f}, 95%CI=[{auc_lower:.3f}, {auc_upper:.3f}])')\n",
    "    \n",
    "    # 绘制置信区间\n",
    "    ax.fill_between(mean_fpr, tpr_lower, tpr_upper, color='blue', alpha=0.2,\n",
    "                    label='95% 置信区间')\n",
    "\n",
    "    # ===== 添加最优cutoff点 =====\n",
    "    # 使用optimal_cutoff计算FPR和TPR\n",
    "    pred_optimal = (all_y_proba >= optimal_cutoff).astype(int)\n",
    "    tn, fp, fn, tp = confusion_matrix(all_y_true, pred_optimal).ravel()\n",
    "    \n",
    "    fpr_cutoff = fp / (fp + tn)  # 假阳性率\n",
    "    tpr_cutoff = tp / (tp + fn)  # 真阳性率（灵敏度）\n",
    "    specificity = tn / (tn + fp)  # 特异度\n",
    "    \n",
    "    # 标注cutoff点\n",
    "    ax.scatter(fpr_cutoff, tpr_cutoff, color='red', s=200, marker='*', \n",
    "              zorder=5, edgecolors='darkred', linewidths=2,\n",
    "              label=f'最优Cutoff = {optimal_cutoff:.2f}')\n",
    "    \n",
    "    ax.plot([0, 1], [0, 1], 'k--', linewidth=2, label='随机分类器')\n",
    "    ax.set_xlabel('假阳性率 (FPR)', fontsize=12, fontweight='bold')\n",
    "    ax.set_ylabel('真阳性率 (TPR)', fontsize=12, fontweight='bold')\n",
    "    ax.set_title('总体 ROC 曲线 (Micro-Average)', fontsize=14, fontweight='bold')\n",
    "    ax.legend(loc='lower right', fontsize=11)\n",
    "    ax.grid(alpha=0.3)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.savefig(save_path_overall, format='pdf', bbox_inches='tight')\n",
    "    plt.close()\n",
    "    print(f\"总体ROC曲线已保存: {save_path_overall}\")\n",
    "    print(f\"最优Cutoff={optimal_cutoff:.2f} | Sensitivity={tpr_cutoff:.3f} | Specificity={specificity:.3f}\")"
