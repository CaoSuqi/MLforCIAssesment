    "# ============================================================\n",
    "# 4) 统计分析函数\n",
    "# ============================================================\n",
    "def compute_all_feature_pvalues(X_raw, labels_df, feature_names):\n",
    "    \"\"\"\n",
    "    计算所有特征的P值，用于筛选显著差异特征\n",
    "    返回按P值排序的特征索引\n",
    "    \"\"\"\n",
    "    mild_mask = (labels_df['label'] == 1).values\n",
    "    sev_mask = (labels_df['label'] == 2).values\n",
    "    \n",
    "    n_features = X_raw.shape[1]\n",
    "    p_values_all = []\n",
    "    \n",
    "    print(\"计算所有特征的组间差异P值...\")\n",
    "    for i in tqdm(range(n_features)):\n",
    "        mild_data = X_raw[mild_mask, i]\n",
    "        sev_data = X_raw[sev_mask, i]\n",
    "        \n",
    "        # Mann-Whitney U检验\n",
    "        stat, p_val = mannwhitneyu(mild_data, sev_data, alternative='two-sided')\n",
    "        p_values_all.append(p_val)\n",
    "    \n",
    "    p_values_all = np.array(p_values_all)\n",
    "    \n",
    "    # 按P值排序（从小到大）\n",
    "    sorted_idx = np.argsort(p_values_all)\n",
    "    \n",
    "    return sorted_idx, p_values_all\n",
    "\n",
    "def compute_feature_statistics(X_raw, labels_df, feature_names, feature_idx):\n",
    "    \"\"\"\n",
    "    计算所有特征的统计检验（P值和校正后的Q值）\n",
    "    \"\"\"\n",
    "    mild_mask = (labels_df['label'] == 1).values\n",
    "    sev_mask = (labels_df['label'] == 2).values\n",
    "    \n",
    "    n_features = X_raw.shape[1]\n",
    "    p_values_all = []\n",
    "    \n",
    "    print(\"计算所有特征的统计检验...\")\n",
    "    for i in tqdm(range(n_features)):\n",
    "        mild_data = X_raw[mild_mask, i]\n",
    "        sev_data = X_raw[sev_mask, i]\n",
    "        \n",
    "        # Mann-Whitney U检验\n",
    "        stat, p_val = mannwhitneyu(mild_data, sev_data, alternative='two-sided')\n",
    "        p_values_all.append(p_val)\n",
    "    \n",
    "    p_values_all = np.array(p_values_all)\n",
    "    \n",
    "    # 多重检验校正（Benjamini-Hochberg FDR）\n",
    "    reject, q_values, _, _ = multipletests(p_values_all, alpha=0.05, method='fdr_bh')\n",
    "    \n",
    "    # 创建DataFrame\n",
    "    stats_df = pd.DataFrame({\n",
    "        'feature_name': feature_names,\n",
    "        'p_value': p_values_all,\n",
    "        'q_value': q_values,\n",
    "        'significant': reject\n",
    "    })\n",
    "    \n",
    "    # 按P值排序\n",
    "    stats_df = stats_df.sort_values('p_value').reset_index(drop=True)\n",
    "    \n",
    "    print(f\"显著性特征数量 (q < 0.05): {reject.sum()}\")\n",
    "    \n",
    "    # Top10特征的统计信息\n",
    "    feature_stats = stats_df[stats_df['feature_name'].isin([feature_names[i] for i in feature_idx])]\n",
    "    \n",
    "    return stats_df, feature_stats"
   ]
