    "def make_xgb_binary(seed=0):\n",
    "    return XGBClassifier(\n",
    "        objective=\"binary:logistic\",\n",
    "        n_estimators=100,#150,200,600,\n",
    "        learning_rate=0.2,#0.15,0.1,0.05\n",
    "        max_depth=3,\n",
    "        subsample=0.8,#0.7,0.9\n",
    "        colsample_bytree=0.9, #0.8 0.7 0.6\n",
    "        reg_lambda=1.0, #2 3\n",
    "        min_child_weight=1.0, #2 3\n",
    "        gamma=0, #0.1 0.2\n",
    "        random_state=seed,\n",
    "        n_jobs=-1,\n",
    "        eval_metric=\"logloss\",\n",
    "    )"
   ]
