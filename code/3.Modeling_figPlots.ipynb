    "# ============================================================\n",
    "# 5) 主评估函数\n",
    "# ============================================================\n",
    "def eval_binary_mild_vs_sev(\n",
    "    X_raw, labels_df, feature_names, cfg, exclude_mice='B1',cut=0.5,seed=0\n",
    "):\n",
    "    \"\"\"\n",
    "    评估函数，包含：\n",
    "    1. 每只鼠的详细指标\n",
    "    2. 特征重要性分析\n",
    "    3. SHAP分析\n",
    "    4. 组间差异统计检验\n",
    "    5. ROC曲线和混淆矩阵\n",
    "    \"\"\"\n",
    "    # 过滤数据\n",
    "    keep_mask = (labels_df[\"mouse\"].astype(str) != exclude_mice).values\n",
    "    X_f = X_raw[keep_mask]\n",
    "    labels_f = labels_df[keep_mask].reset_index(drop=True)\n",
    "    \n",
    "    mice_sorted = sorted(labels_f[\"mouse\"].astype(str).unique().tolist())\n",
    "\n",
    "    # 存储结果\n",
    "    rows = []\n",
    "    cm_sum = np.zeros((2, 2), dtype=int)\n",
    "    all_fpr = []\n",
    "    all_tpr = []\n",
    "    all_y_true = []\n",
    "    all_y_proba = []\n",
    "    all_confusion_matrices = []\n",
    "    feature_importance_list = []\n",
    "    \n",
    "    # SHAP值存储\n",
    "    all_shap_values = []\n",
    "    all_X_test = []\n",
    "\n",
    "    print(\"开始留一法交叉验证...\\n\")\n",
    "    for k, test_mouse in enumerate(mice_sorted):\n",
    "        print(f\"Fold {k+1}/{len(mice_sorted)}: 测试小鼠 = {test_mouse}\")\n",
    "        \n",
    "        test_mask_full = (labels_f[\"mouse\"].astype(str).values == test_mouse)\n",
    "        train_mask_full = ~test_mask_full\n",
    "\n",
    "        # 训练/测试样本：仅取 MILD(label=1)/SEV(label=2)\n",
    "        tr_idx = np.where(train_mask_full & labels_f[\"label\"].isin([1, 2]).values)[0]\n",
    "        te_idx = np.where(test_mask_full & labels_f[\"label\"].isin([1, 2]).values)[0]\n",
    "\n",
    "        # y 映射：MILD=0, SEV=1\n",
    "        ytr = (labels_f.loc[tr_idx, \"label\"].values == 2).astype(int)\n",
    "        yte = (labels_f.loc[te_idx, \"label\"].values == 2).astype(int)\n",
    "\n",
    "        # baseline拟合：只用训练鼠的day0（健康）\n",
    "        baseline_train_idx = np.where(train_mask_full)[0]\n",
    "        baseline = fit_population_healthy_baseline_median_of_mice(\n",
    "            X_f, labels_f, train_idx=baseline_train_idx, by_electrode=True\n",
    "        )\n",
    "        Xtr = transform_with_baseline(X_f[tr_idx], labels_f.iloc[tr_idx].reset_index(drop=True), baseline, cfg.EPS)\n",
    "        Xte = transform_with_baseline(X_f[te_idx], labels_f.iloc[te_idx].reset_index(drop=True), baseline, cfg.EPS)\n",
    "\n",
    "        # 训练模型\n",
    "        model = make_xgb_binary(seed=seed)\n",
    "        model.fit(Xtr, ytr)\n",
    "\n",
    "        # 预测\n",
    "        proba = model.predict_proba(Xte)[:, 1]\n",
