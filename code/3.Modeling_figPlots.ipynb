    "        print(f\"  召回率(MILD,SEV)=[{rec[0]:.3f},{rec[1]:.3f}] | 精确率(MILD,SEV)=[{prec[0]:.3f},{prec[1]:.3f}]\\n\")\n",
    "\n",
    "    # 汇总结果\n",
    "    df_results = pd.DataFrame(rows)\n",
