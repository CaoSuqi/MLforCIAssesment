    "# --------------------------\n",
    "# 1) Baseline (median-of-mice) for healthy day0\n",
    "# --------------------------\n",
    "def _iqr(x, axis=0):\n",
    "    return np.quantile(x, 0.75, axis=axis) - np.quantile(x, 0.25, axis=axis)\n",
    "\n",
    "def fit_population_healthy_baseline_median_of_mice(\n",
    "    X_raw: np.ndarray,\n",
    "    labels_df: pd.DataFrame,\n",
    "    train_idx: np.ndarray,\n",
    "    by_electrode: bool = True,\n",
    "):\n",
    "    \"\"\"\n",
    "    用训练集中的健康(day==0)估计群体基线，策略=median-of-mice：\n",
    "      - 先按 mouse 对健康样本取 median 向量\n",
    "      - 再对这些“鼠代表向量”取 median/IQR\n",
    "\n",
    "    by_electrode=True: 每个electrode单独估计一套 (median, IQR)\n",
    "    \"\"\"\n",
    "    idx = np.asarray(train_idx)\n",
    "\n",
    "    # 健康定义：day==0（与你实验一致）\n",
    "    healthy_mask = (labels_df.loc[idx, \"day\"].values == 0)\n",
    "    healthy_idx = idx[healthy_mask]\n",
    "    if len(healthy_idx) == 0:\n",
    "        raise ValueError(\"No healthy(day==0) samples in training split.\")\n",
    "\n",
    "    mice = labels_df.loc[healthy_idx, \"mouse\"].astype(str).values\n",
    "    elec = labels_df.loc[healthy_idx, \"electrode\"].astype(int).values\n",
    "    Xh = X_raw[healthy_idx]  # (Nh, F)\n",
    "\n",
    "    F = X_raw.shape[1]\n",
    "\n",
    "    if by_electrode:\n",
    "        E = int(labels_df[\"electrode\"].max()) + 1\n",
    "        base_med = np.zeros((E, F), dtype=np.float32)\n",
    "        base_iqr = np.zeros((E, F), dtype=np.float32)\n",
    "\n",
    "        for e in np.unique(elec):\n",
    "            # 在该电极上，按鼠聚合\n",
    "            mlist = np.unique(mice[elec == e])\n",
    "            M = []\n",
    "            for m in mlist:\n",
    "                Xm = Xh[(elec == e) & (mice == m)]\n",
    "                M.append(np.median(Xm, axis=0))\n",
    "            M = np.stack(M, axis=0)  # (#mice, F)\n",
    "\n",
    "            base_med[e] = np.median(M, axis=0)\n",
    "            base_iqr[e] = _iqr(M, axis=0) + EPS\n",
    "\n",
    "        return {\"median\": base_med, \"iqr\": base_iqr, \"by_electrode\": True}\n",
    "\n",
    "    else:\n",
    "        mlist = np.unique(mice)\n",
    "        M = []\n",
    "        for m in mlist:\n",
    "            Xm = Xh[mice == m]\n",
    "            M.append(np.median(Xm, axis=0))\n",
    "        M = np.stack(M, axis=0)\n",
    "\n",
    "        base_med = np.median(M, axis=0).astype(np.float32)\n",
    "        base_iqr = (_iqr(M, axis=0) + EPS).astype(np.float32)\n",
    "        return {\"median\": base_med, \"iqr\": base_iqr, \"by_electrode\": False}\n",
    "\n",
    "def transform_with_baseline(\n",
    "    X_raw: np.ndarray,\n",
    "    labels_part: pd.DataFrame,\n",
    "    baseline: dict,\n",
    "    EPS:1e-8,\n",
    "):\n",
    "    \"\"\"X_raw -> Z-healthy\"\"\"\n",
    "    if baseline[\"by_electrode\"]:\n",
    "        med = baseline[\"median\"]\n",
    "        iqr = baseline[\"iqr\"]\n",
    "        elec = labels_part[\"electrode\"].astype(int).values\n",
    "        Z = (X_raw - med[elec]) / (iqr[elec] + EPS)\n",
    "    else:\n",
    "        Z = (X_raw - baseline[\"median\"]) / (baseline[\"iqr\"] + EPS)\n",
    "    return Z.astype(np.float32)"
   ]
  },
