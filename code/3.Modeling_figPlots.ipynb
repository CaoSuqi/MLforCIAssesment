    "# ============================================================\n",
    "# 6) 主执行流程\n",
    "# ============================================================\n",
    "if __name__ == \"__main__\":\n",
    "    cfg = CFG()\n",
    "    # 加载数据\n",
    "    d = np.load(cfg.NPZ_PATH, allow_pickle=False)\n",
    "    X_raw = d[\"X\"].astype(np.float32)\n",
    "    y = d[\"y\"].astype(np.int64)\n",
    "    groups_mouse = d[\"groups_mouse\"].astype(np.int64)\n",
    "    EPS = cfg.EPS\n",
    "    labels = pd.read_csv(cfg.LABELS_CSV)\n",
    "    \n",
    "    try:\n",
    "        feature_names = [str(s) for s in d[\"feature_names\"]]\n",
    "    except Exception:\n",
    "        raise ValueError(\"NPZ文件中不包含feature_names，请重新保存\")\n",
    "    \n",
    "    print(f\"数据形状: X={X_raw.shape}, y={y.shape}\")\n",
    "    print(f\"特征数量: {len(feature_names)}\")\n",
    "    print(f\"样本数量: {len(labels)}\")\n",
    "    \n",
    "    # 运行增强版评估\n",
    "    results = eval_binary_mild_vs_sev(\n",
    "        X_raw, labels, feature_names, cfg,\n",
    "        exclude_mice=cfg.EXCLUDE_MICE,cut=0.42,\n",
    "        seed=1777\n",
    "    )\n",
    "    \n",
    "    # 保存指标CSV\n",
    "    print(\"\\n3. 保存结果...\")\n",
    "    results['df_results'].to_csv(cfg.METRICS_PER_MOUSE_CSV, index=False, encoding='utf-8-sig')\n",
    "    print(f\"每只小鼠指标已保存: {cfg.METRICS_PER_MOUSE_CSV}\")\n",
    "    \n",
    "    # 保存总体统计\n",
    "    summary_stats = results['df_results'].describe().T\n",
    "    summary_stats.to_csv(cfg.METRICS_CSV, encoding='utf-8-sig')\n",
    "    print(f\"总体统计已保存: {cfg.METRICS_CSV}\")\n",
    "    \n",
    "    # 特征重要性分析\n",
    "    print(\"\\n4. 特征重要性分析...\")\n",
    "    top10_idx, top10_names, all_sorted_idx = plot_feature_importance_top10(\n",
    "        results['mean_feature_importance'],\n",
    "        feature_names,\n",
    "        cfg.FEATURE_IMPORTANCE_PDF\n",
    "    )\n",
    "    \n",
    "    # 保存特征重要性CSV\n",
    "    importance_all_df = pd.DataFrame({\n",
    "        'rank': range(1, len(feature_names) + 1),\n",
    "        'feature_name': [feature_names[i] for i in all_sorted_idx],\n",
    "        'importance': results['mean_feature_importance'][all_sorted_idx]\n",
    "    })\n",
    "    importance_all_df.to_csv(cfg.FEATURE_IMPORTANCE_CSV, index=False, encoding='utf-8-sig')\n",
    "    print(f\"特征重要性已保存: {cfg.FEATURE_IMPORTANCE_CSV}\")\n",
    "    \n",
    "    # 组间差异箱线图和统计检验\n",
    "    print(\"\\n5. 组间差异分析...\")\n",
    "    \n",
    "    # 计算所有特征的P值和Q值\n",
    "    sorted_idx_by_pval, all_pvalues = compute_all_feature_pvalues(X_raw, labels, feature_names)\n",
    "    stats_df, feature_stats = compute_feature_statistics(\n",
    "        X_raw, labels, feature_names, sorted_idx_by_pval  # 注意这里改用significance的索引\n",
    "    )\n",
    "    stats_df.to_csv(cfg.FEATURE_PVALUES_CSV, index=False, encoding='utf-8-sig')\n",
    "    print(f\"所有特征的P值和Q值已保存: {cfg.FEATURE_PVALUES_CSV}\")\n",
    "    \n",
    "    significant_features_df = plot_significant_features_boxplot(\n",
    "        X_raw, labels, stats_df, feature_names,\n",
    "        cfg.FEATURE_BOXPLOT_PDF,\n",
    "        max_features=20,  # 最多显示20个\n",
    "        outlier_percentile=99,\n",
    "        use_qvalue=True  # 使用FDR校正后的Q值\n",
    "    )\n",
    "\n",
    "    \n",
    "    # SHAP分析\n",
    "    print(\"\\n6. SHAP可解释性分析...\")\n",
    "    plot_shap_analysis(\n",
    "        results['all_shap_values'],\n",
    "        results['all_X_test'],\n",
    "        feature_names,\n",
    "        cfg.SHAP_SUMMARY_PDF,\n",
    "        cfg.SHAP_BAR_PDF\n",
    "    )\n",
    "    \n",
    "    # 混淆矩阵\n",
    "    print(\"\\n7. 绘制混淆矩阵...\")\n",
    "    plot_confusion_matrices(\n",
    "        results['all_confusion_matrices'],\n",
    "        results['cm_sum'],\n",
    "        cfg.CM_INDIVIDUAL_PDF,\n",
    "        cfg.CM_OVERALL_PDF\n",
    "    )\n",
    "    \n",
    "    # ROC曲线\n",
    "    print(\"\\n8. 绘制ROC曲线...\")\n",
    "    plot_roc_curves(\n",
    "        results['all_fpr'],\n",
