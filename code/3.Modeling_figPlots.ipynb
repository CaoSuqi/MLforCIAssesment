    "        f1 = f1_score(yte, pred)\n",
    "        rec_avg = recall_score(yte, pred)\n",
    "        prec_avg = precision_score(yte, pred)\n",
    "        rec = recall_score(yte, pred, average=None, labels=[0, 1])  # [MILD, SEV]\n",
    "        prec = precision_score(yte, pred, average=None, labels=[0, 1], zero_division=0)\n",
    "        \n",
    "        try:\n",
    "            auc_score = roc_auc_score(yte, proba)\n",
    "        except Exception:\n",
    "            auc_score = np.nan\n",
    "\n",
    "        # 混淆矩阵\n",
    "        cm = confusion_matrix(yte, pred, labels=[0, 1])\n",
    "        cm_sum += cm\n",
