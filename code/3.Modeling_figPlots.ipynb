    "# ============================================================\n",
    "# 3) 可视化函数\n",
    "# ============================================================\n",
    "def plot_feature_importance_top10(mean_importance, feature_names, save_path):\n",
    "    \"\"\"绘制Top10特征重要性柱状图\"\"\"\n",
    "    # 获取所有特征按重要性排序的索引\n",
    "    all_sorted_idx = np.argsort(mean_importance)[::-1]  # 降序排列\n",
    "    # 获取Top10特征\n",
    "    top10_idx = np.argsort(mean_importance)[-10:][::-1]\n",
    "    top10_importance = mean_importance[top10_idx]\n",
    "    top10_names = [feature_names[i] for i in top10_idx]\n",
    "    \n",
    "    fig, ax = plt.subplots(figsize=(10, 6))\n",
    "    bars = ax.barh(range(10), top10_importance, color='steelblue', edgecolor='black')\n",
    "    ax.set_yticks(range(10))\n",
    "    ax.set_yticklabels(top10_names)\n",
    "    ax.set_xlabel('特征重要性', fontsize=12, fontweight='bold')\n",
    "    ax.set_title('Top 10 特征重要性排序', fontsize=14, fontweight='bold')\n",
    "    ax.invert_yaxis()\n",
    "    \n",
    "    # 添加数值标签\n",
    "    for i, (bar, val) in enumerate(zip(bars, top10_importance)):\n",
    "        ax.text(val, i, f' {val:.4f}', va='center', fontsize=10)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.savefig(save_path, format='pdf', bbox_inches='tight')\n",
    "    plt.close()\n",
    "    print(f\"特征重要性柱状图已保存: {save_path}\")\n",
    "    \n",
    "    return top10_idx, top10_names,all_sorted_idx\n",
    "\n",
    "def plot_significant_features_boxplot(X_raw, labels_df, stats_df, feature_names, save_path,\n",
    "                                     max_features=20, outlier_percentile=99,\n",
    "                                     use_qvalue=True):\n",
    "    \"\"\"\n",
    "    绘制统计学显著差异特征的箱线图\n",
    "    \n",
    "    参数:\n",
    "        X_raw: 特征矩阵\n",
    "        labels_df: 标签数据框\n",
    "        stats_df: compute_feature_statistics返回的统计结果DataFrame\n",
    "        feature_names: 特征名称列表\n",
    "        save_path: 保存路径\n",
    "        max_features: 最多显示多少个特征（默认20，如果显著特征少于此数则显示全部）\n",
    "        outlier_percentile: 用于限制y轴范围的百分位数（默认99）\n",
    "        use_qvalue: True=使用Q值判断显著性(FDR校正后), False=使用P值<0.05\n",
    "    \n",
    "    返回:\n",
    "        significant_features_df: 显著特征的详细信息\n",
    "    \"\"\"\n",
    "    # 筛选显著特征\n",
    "    if use_qvalue:\n",
    "        # 使用FDR校正后的Q值\n",
    "        significant_df = stats_df[stats_df['significant'] == True].copy()\n",
    "        criterion = \"Q值 < 0.05 (FDR校正)\"\n",
    "    else:\n",
    "        # 使用未校正的P值\n",
    "        significant_df = stats_df[stats_df['p_value'] < 0.05].copy()\n",
    "        criterion = \"P值 < 0.05 (未校正)\"\n",
    "    \n",
    "    n_significant = len(significant_df)\n",
    "    \n",
    "    print(f\"\\n显著差异特征筛选 (标准: {criterion}):\")\n",
    "    print(f\"  - 总特征数: {len(stats_df)}\")\n",
    "    print(f\"  - 显著特征数: {n_significant}\")\n",
    "    \n",
    "    if n_significant == 0:\n",
    "        print(\"  ⚠️ 没有发现显著差异的特征！\")\n",
    "        return None\n",
    "    \n",
    "    # 限制显示数量\n",
    "    n_to_plot = min(n_significant, max_features)\n",
    "    if n_significant > max_features:\n",
    "        print(f\"  - 显著特征过多，仅展示P值最小的前{max_features}个\")\n",
    "        significant_df = significant_df.head(max_features)\n",
    "    \n",
    "    # 获取要绘制的特征索引\n",
    "    feature_indices = []\n",
    "    for fname in significant_df['feature_name']:\n",
    "        feature_indices.append(feature_names.index(fname))\n",
    "    \n",
    "    print(f\"\\n将绘制以下{n_to_plot}个显著特征:\")\n",
    "    for i, (idx, row) in enumerate(zip(feature_indices, significant_df.itertuples()), 1):\n",
    "        if use_qvalue:\n",
    "            print(f\"  {i}. {row.feature_name}: p={row.p_value:.2e}, q={row.q_value:.2e}\")\n",
    "        else:\n",
    "            print(f\"  {i}. {row.feature_name}: p={row.p_value:.2e}\")\n",
    "    \n",
    "    # ========== 开始绘图 ==========\n",
    "    mild_mask = (labels_df['label'] == 1).values\n",
    "    sev_mask = (labels_df['label'] == 2).values\n",
    "    \n",
    "    n_cols = 2\n",
    "    n_rows = (n_to_plot + n_cols - 1) // n_cols\n",
    "    \n",
    "    fig, axes = plt.subplots(n_rows, n_cols, figsize=(14, 4*n_rows))\n",
    "    axes = axes.flatten() if n_to_plot > 1 else [axes]\n",
    "    \n",
    "    for i, (idx, row) in enumerate(zip(feature_indices, significant_df.itertuples())):\n",
    "        ax = axes[i]\n",
    "        \n",
    "        # 准备数据\n",
    "        mild_data = X_raw[mild_mask, idx]\n",
    "        sev_data = X_raw[sev_mask, idx]\n",
    "        \n",
    "        p_val = row.p_value\n",
    "        q_val = row.q_value\n",
    "        \n",
    "        # 计算效应量（Cohen's d）\n",
    "        pooled_std = np.sqrt((np.var(mild_data) + np.var(sev_data)) / 2)\n",
    "        if pooled_std > 0:\n",
    "            cohen_d = (np.mean(sev_data) - np.mean(mild_data)) / pooled_std\n",
    "        else:\n",
    "            cohen_d = 0\n",
    "        \n",
    "        # 计算合理的y轴范围\n",
    "        all_data = np.concatenate([mild_data, sev_data])\n",
    "        \n",
    "        y_lower = np.percentile(all_data, 100 - outlier_percentile)\n",
    "        y_upper = np.percentile(all_data, outlier_percentile)\n",
    "        \n",
    "        q1, q3 = np.percentile(all_data, [25, 75])\n",
    "        iqr = q3 - q1\n",
    "        y_lower_iqr = q1 - 4 * iqr\n",
    "        y_upper_iqr = q3 + 4 * iqr\n",
    "        \n",
    "        y_min = max(y_lower, y_lower_iqr)\n",
    "        y_max = min(y_upper, y_upper_iqr)\n",
    "        \n",
    "        y_range = y_max - y_min\n",
    "        if y_range == 0:\n",
    "            y_range = 1\n",
    "            y_min -= 0.5\n",
    "            y_max += 0.5\n",
    "        \n",
    "        y_min_plot = y_min - 0.05 * y_range\n",
    "        y_max_plot = y_max + 0.25 * y_range\n",
    "        \n",
    "        # 统计被过滤的异常值\n",
    "        mild_data_in_range = mild_data[(mild_data >= y_min) & (mild_data <= y_max)]\n",
    "        sev_data_in_range = sev_data[(sev_data >= y_min) & (sev_data <= y_max)]\n",
    "        n_mild_filtered = len(mild_data) - len(mild_data_in_range)\n",
    "        n_sev_filtered = len(sev_data) - len(sev_data_in_range)\n",
    "        \n",
    "        # 绘制箱线图\n",
    "        data_to_plot = [mild_data, sev_data]\n",
    "        bp = ax.boxplot(data_to_plot, labels=['MILD', 'SEVERE'], patch_artist=True,\n",
    "                       widths=0.6, showfliers=True,\n",
    "                       flierprops=dict(marker='o', markerfacecolor='gray', markersize=4,\n",
    "                                      linestyle='none', alpha=0.5))\n",
    "        \n",
    "        # 设置颜色\n",
    "        colors = ['lightblue', 'lightcoral']\n",
    "        for patch, color in zip(bp['boxes'], colors):\n",
    "            patch.set_facecolor(color)\n",
    "            patch.set_alpha(0.7)\n",
    "        \n",
    "        # 设置y轴范围\n",
    "        ax.set_ylim(y_min_plot, y_max_plot)\n",
    "        \n",
    "        # 显著性标记\n",
    "        if p_val < 0.001:\n",
    "            sig_text = '***'\n",
    "        elif p_val < 0.01:\n",
    "            sig_text = '**'\n",
    "        elif p_val < 0.05:\n",
    "            sig_text = '*'\n",
    "        else:\n",
    "            sig_text = 'ns'\n",
    "        \n",
    "        # 显著性标注（根据选择显示P值或Q值）\n",
    "        p_y_position = y_max_plot - 0.03 * y_range\n",
    "        if use_qvalue:\n",
    "            ax.text(1.5, p_y_position,\n",
    "                   f'P = {p_val:.2e}\\nQ = {q_val:.2e}\\n{sig_text}\\nCohen\\'s d = {cohen_d:.2f}',\n",
    "                   ha='center', va='top', fontsize=9, fontweight='bold',\n",
    "                   bbox=dict(boxstyle='round,pad=0.5', facecolor='lightyellow', alpha=0.8))\n",
    "        else:\n",
    "            ax.text(1.5, p_y_position,\n",
    "                   f'P = {p_val:.2e}\\n{sig_text}\\nCohen\\'s d = {cohen_d:.2f}',\n",
    "                   ha='center', va='top', fontsize=9, fontweight='bold',\n",
    "                   bbox=dict(boxstyle='round,pad=0.5', facecolor='lightyellow', alpha=0.8))\n",
    "        \n",
    "        # 连接线\n",
    "        line_y = y_max_plot - 0.08 * y_range\n",
    "        ax.plot([1, 2], [line_y, line_y], 'k-', linewidth=1.5)\n",
    "        \n",
    "        ax.set_ylabel('特征值', fontsize=10)\n",
    "        ax.set_title(f'#{i+1}: {row.feature_name}', fontsize=11, fontweight='bold')\n",
    "        ax.grid(axis='y', alpha=0.3)\n",
    "        \n",
    "        # 添加过滤信息\n",
    "        if n_mild_filtered > 0 or n_sev_filtered > 0:\n",
    "            ax.text(0.02, 0.02,\n",
    "                   f'隐藏极端值:\\nMILD: {n_mild_filtered}\\nSEV: {n_sev_filtered}',\n",
    "                   transform=ax.transAxes, fontsize=7, verticalalignment='bottom',\n",
    "                   bbox=dict(boxstyle='round', facecolor='wheat', alpha=0.6))\n",
    "        \n",
    "        # 添加样本量信息\n",
    "        ax.text(0.98, 0.02,\n",
    "               f'n(MILD)={len(mild_data)}\\nn(SEV)={len(sev_data)}',\n",
    "               transform=ax.transAxes, fontsize=7, verticalalignment='bottom',\n",
    "               horizontalalignment='right',\n",
    "               bbox=dict(boxstyle='round', facecolor='lightgray', alpha=0.6))\n",
    "    \n",
    "    # 隐藏多余子图\n",
    "    for i in range(n_to_plot, len(axes)):\n",
    "        axes[i].axis('off')\n",
    "    \n",
    "    # 总标题\n",
    "    if use_qvalue:\n",
    "        title = f'统计学显著差异特征 (Q < 0.05, FDR校正)\\n共{n_significant}个显著特征，展示前{n_to_plot}个'\n",
    "    else:\n",
    "        title = f'统计学显著差异特征 (P < 0.05, 未校正)\\n共{n_significant}个显著特征，展示前{n_to_plot}个'\n",
    "    \n",
    "    fig.suptitle(title, fontsize=14, fontweight='bold', y=0.995)\n",
    "    \n",
